# RecallBot Environment Variables

# ─── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_TOKEN="your_whatsapp_cloud_api_token"
PHONE_NUMBER_ID="your_phone_number_id"
TO_PHONE_NUMBER="your_phone_number_with_country_code"
ENABLE_WHATSAPP=true

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key"

# ─── Google OAuth (for cloud deployment) ───────────────────────────────────────
# Option 1: Set these env vars (recommended for cloud)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="https://your-app.onrender.com/auth/google/callback"
# Option 2: Place credentials.json in the project root (for local dev)

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI="YOUR_MONGODB_CONNECTION_STRING_HERE"

# ─── Server ────────────────────────────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN="recallbot_verify_2026"
PORT=3000
